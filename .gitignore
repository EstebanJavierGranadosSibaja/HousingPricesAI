# Python cache and bytecode
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/
.env

/COMPAÑERO

# Distribution / packaging
build/
dist/
*.egg-info/
*.dist-info/
.eggs/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# PyInstaller
*.manifest
*.spec

# Unit test / coverage
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
.pytest_cache/
nosetests.xml
coverage.xml

# Jupyter
.ipynb_checkpoints/
notebooks/*-checkpoint.ipynb

# VS Code
.vscode/

# OS generated files
.DS_Store
Thumbs.db
desktop.ini

# Logs
logs/
*.log

# Model and artifact files
models/
outputs/
*.h5
*.hdf5
*.pt
*.pth
*.ckpt
*.pkl
*.joblib

# Data files
# Se ignora todo por defecto, pero se versionan los archivos minimos para
# que el proyecto funcione al clonar en otra maquina.
data/raw/*
!data/raw/.gitkeep
!data/raw/train.csv
!data/raw/test.csv
!data/raw/sample_submission.csv
data/processed/*.csv
!data/processed/.gitkeep

# Generated reports
reports/diagnostics/*

# Secrets and environment
.env.local
.env.*.local
secrets/
*.pem
*.key

# Python packaging leftovers
*.egg

# Windows shortcuts
*.lnk
