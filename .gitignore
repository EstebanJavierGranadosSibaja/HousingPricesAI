# Data files (opcional)
# Ignorar datos RAW (recomendado). Para versionar un archivo pequeño de control,
# deje `data/raw/.gitkeep` y quite la negación si necesita versionar datasets.
data/raw/*
!data/raw/.gitkeep
#/house-prices-advanced-regression-techniques/*.csv

# Secrets and environment
.env.local
.env.*.local
secrets/
*.pem
*.key

# Python packaging leftovers
*.egg
*.egg-info/
*.dist-info/

# Byte-compiled / caches
*.pyc
*.pyo

# Windows shortcuts
*.lnk
